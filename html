<script>
function show(tab){
  document.querySelectorAll('.view').forEach(function(v){v.classList.remove('active')});
  document.querySelectorAll('.toggle-btn').forEach(function(b){b.classList.remove('active')});
  document.getElementById(tab).classList.add('active');
  document.querySelectorAll('.toggle-btn.'+tab).forEach(function(b){b.classList.add('active')});
}
function openQ(){
  document.getElementById('quizOverlay').style.display='block';
  document.getElementById('qpf').style.width='25%';
}
function closeQ(){
  document.getElementById('quizOverlay').style.display='none';
  ['qq1','qq2','qq3'].forEach(function(id){document.getElementById(id).style.display='none'});
  document.getElementById('qq1').style.display='block';
  document.getElementById('qpf').style.width='25%';
}
function nextQ(n,pct){
  ['qq1','qq2','qq3'].forEach(function(id){document.getElementById(id).style.display='none'});
  document.getElementById('qq'+n).style.display='block';
  document.getElementById('qpf').style.width=pct+'%';
}
</script>

